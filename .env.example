APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

BUNNY_STORAGE_NAME=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_REGION=de
BUNNY_STORAGE_API_URL=https://storage.bunnycdn.com
BUNNY_CDN_URL=
BUNNY_TIMEOUT_SECONDS=20
BUNNY_RETRY_TIMES=3
BUNNY_RETRY_SLEEP_MS=300
# false only for local dev if cURL SSL fails (OpenServer / self-signed chain)
BUNNY_VERIFY_SSL=true
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Nova Poshta (https://my.novaposhta.ua/settings/index#apikeys)
NOVA_POSHTA_API_KEY=69bea1e8827d6036c7d1e58014efdc676e1f76df
NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/
NOVA_POSHTA_TIMEOUT=20
# false on local OpenServer if cURL SSL fails (self-signed certificate in chain)
NOVA_POSHTA_VERIFY_SSL=false

# Telegram (forms notifications). false — якщо cURL на хостингу падає на SSL до api.telegram.org
TELEGRAM_VERIFY_SSL=false

# LiqPay (https://www.liqpay.ua/)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=true
LIQPAY_CURRENCY=UAH
LIQPAY_CHECKOUT_URL=https://www.liqpay.ua/api/3/checkout

# Checkout
CHECKOUT_SHIPPING_COST=0
CHECKOUT_IBAN_RECIPIENT=
CHECKOUT_IBAN_NUMBER=
CHECKOUT_IBAN_BANK=
CHECKOUT_IBAN_PURPOSE=Оплата замовлення NOEMA

NOEMA_COLOR_BLACK_BRAND=#010101
NOEMA_COLOR_WHITE=#FFFFFF
NOEMA_COLOR_GRAY_TEXT=#BABABA
NOEMA_COLOR_BLACK_BRAND_2=#070707
NOEMA_COLOR_BLUE_BRAND=#526882

VITE_APP_NAME="${APP_NAME}"
